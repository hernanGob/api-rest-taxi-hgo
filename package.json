{
  "name": "api-taxihgo",
  "version": "0.0.1",
  "description": "API REST para app Taxis Hgo",
  "license": "ISC",
  "author": "Dirección General de Innovación Gubernamental",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "nodemon --watch src --ext ts,js,json --exec tsx src/server.ts",
    "migration": "npx drizzle-kit generate --config=src/drizzle.config.ts",
    "apply:migration": "npx drizzle-kit migrate --config=src/drizzle.config.ts",
    "db:generate": "npx drizzle-kit generate --config=src/drizzle.config.ts",
    "seed": "tsx src/config/drizzle/seed.ts"
  },
  "dependencies": {
    "argon2": "^0.44.0",
    "axios": "^1.16.1",
    "compression": "^1.8.1",
    "cookie": "^1.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.1",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.3",
    "otpauth": "^9.5.1",
    "pg": "^8.20.0",
    "qrcode": "^1.5.4",
    "redis": "^5.12.1",
    "socket.io": "^4.8.3",
    "uuid": "^14.0.0",
    "validator": "^13.15.35"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cookie": "^0.6.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/hpp": "^0.2.7",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.6",
    "@types/validator": "^13.15.10",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.2.1",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.3",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
